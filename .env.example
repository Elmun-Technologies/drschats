# Shopflow platform integration
# SHOPFLOW_MODE: "mock" (built-in sample data) | "http" (real Shopflow API)
SHOPFLOW_MODE=mock
SHOPFLOW_API_URL=https://api.shopflow.example/v1
SHOPFLOW_API_KEY=

# Public site URL (used for canonical, sitemap, OG, hreflang)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Analytics / context-ads (optional — leave blank to disable)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_YANDEX_METRIKA_ID=
